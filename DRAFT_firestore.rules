rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- GLOBAL HELPERS ---
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }
    
    // Admin check based on specific email (only if using Google Auth)
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'motelposeidonsantarosa@gmail.com' && request.auth.token.email_verified == true
      );
    }

    // --- COLLECTIONS ---

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // 1. App Users (Read allowed for PIN auth, Write allowed for initial bootstrap and admin)
    match /app_users/{userId} {
      allow read: if true; 
      allow create, update: if isValidAppUser(incoming());
      allow delete: if isAdmin() || true; // Allow for now until auth is stabilized
    }

    function isValidAppUser(data) {
      return data.keys().hasAll(['id', 'name', 'role', 'pin', 'active'])
        && data.id is string
        && data.name is string
        && data.role in ['admin', 'host']
        && data.pin is string;
    }

    // 2. Rooms
    match /rooms/{roomId} {
      allow read: if true;
      allow create, update: if isValidRoom(incoming());
      allow delete: if isAdmin() || true; 
    }

    function isValidRoom(data) {
      return data.keys().hasAll(['id', 'name', 'status'])
        && data.id is string
        && data.name is string;
    }

    // 3. Products
    match /products/{productId} {
      allow read: if true;
      allow create, update: if isValidProduct(incoming());
      allow delete: if isAdmin() || true;
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'stock', 'category'])
        && data.name is string
        && data.price is number
        && data.stock is number;
    }

    // 4. Promos/Info (Inventory/Catalog Info Tab)
    match /promos/{promoId} {
      allow read: if true;
      allow create, update: if true; // Very flexible for images
      allow delete: if true;
    }

    // 5. Tickets
    match /tickets/{ticketId} {
      allow read: if true;
      allow create, update: if isValidTicket(incoming());
      allow delete: if true;
    }

    function isValidTicket(data) {
      return data.keys().hasAll(['roomId', 'roomName', 'total', 'date', 'hostName'])
        && data.roomId is string
        && data.total is number;
    }

    // 6. Expenses
    match /expenses/{expenseId} {
      allow read: if true;
      allow create, update: if isValidExpense(incoming());
      allow delete: if true;
    }

    function isValidExpense(data) {
      return data.keys().hasAll(['description', 'amount', 'category', 'date', 'hostName'])
        && data.amount is number;
    }

    // 7. Reservations
    match /reservations/{reservationId} {
      allow read: if true;
      allow create, update: if isValidReservation(incoming());
      allow delete: if true;
    }

    function isValidReservation(data) {
      return data.keys().hasAll(['roomId', 'roomName', 'clientName', 'date', 'status'])
        && data.status in ['pending', 'cancelled', 'completed'];
    }

    // 8. Shifts
    match /shifts/{shiftId} {
      allow read: if true;
      allow create, update: if true; // Shifts are critical for operational flow
      allow delete: if isAdmin() || true;
    }

    // 9. Incidents
    match /incidents/{incidentId} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if true;
    }

    // 10. Notifications
    match /notifications/{notificationId} {
      allow read: if true;
      allow create, delete: if true;
    }

    // 11. Settings (Invoice, Financials)
    match /settings/{settingId} {
      allow read, write: if true;
    }

    // 12. Transaction history / resets
    match /resets/{resetId} {
      allow read, write: if true;
    }
  }
}
