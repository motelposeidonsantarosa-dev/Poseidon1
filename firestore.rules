rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    // Note: The application uses a custom PIN-based authentication system 
    // stored in 'app_users' and does not currently use Firebase Auth (request.auth).
    // To fix the "Missing or insufficient permissions" error, we allow access
    // to the necessary collections.
    
    function isValidAppUser(data) {
      return data.id is string &&
             data.name is string &&
             data.role in ['admin', 'host'] &&
             data.pin is string &&
             data.active is bool;
    }

    function isValidRoom(data) {
      return data.id is string &&
             data.name is string &&
             data.status in ['Libre', 'Ocupada', 'Limpieza'] &&
             data.persons is number &&
             data.total is number;
    }

    function isValidReservation(data) {
      return data.roomId is string &&
             data.roomName is string &&
             data.clientName is string &&
             data.status in ['pending', 'cancelled', 'completed'] &&
             data.date is string &&
             data.createdAt is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Custom Users collection (used for login)
    match /app_users/{userId} {
      // Allow read so the login screen can list users and verify PIN
      allow read: if true;
      // Allow create/update for admin actions (managed via app logic)
      allow write: if true; 
    }

    // Rooms collection
    match /rooms/{roomId} {
      allow read, write: if true;
    }

    // Products (Inventory)
    match /products/{productId} {
      allow read, write: if true;
    }

    // Tickets (History)
    match /tickets/{ticketId} {
      allow read, write: if true;
    }

    // Expenses
    match /expenses/{expenseId} {
      allow read, write: if true;
    }

    // Reservations
    match /reservations/{reservationId} {
      allow read, write: if true;
    }

    // Shifts
    match /shifts/{shiftId} {
      allow read, write: if true;
    }

    // Settings
    match /settings/{settingId} {
      allow read, write: if true;
    }
  }
}
