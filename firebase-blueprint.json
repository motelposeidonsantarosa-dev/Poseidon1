{
  "entities": {
    "AppUser": {
      "title": "AppUser",
      "description": "A user of the system (admin or host) with PIN auth",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "host"] },
        "pin": { "type": "string" },
        "active": { "type": "boolean" }
      },
      "required": ["id", "name", "role", "pin", "active"]
    },
    "Room": {
      "title": "Room",
      "description": "A motel room",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "status": { "type": "string", "enum": ["Libre", "Ocupada", "Limpieza"] },
        "startTime": { "type": "string", "format": "date-time", "description": "ISO string or null" },
        "endTime": { "type": "string", "format": "date-time", "description": "ISO string or null" },
        "persons": { "type": "number" },
        "images": { "type": "array", "items": { "type": "string" }, "description": "Array of base64 or URL images" },
        "description": { "type": "string" },
        "services": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "price": { "type": "number" },
              "quantity": { "type": "number" }
            }
          }
        },
        "products": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "price": { "type": "number" },
              "quantity": { "type": "number" }
            }
          }
        },
        "total": { "type": "number" },
        "currentHostId": { "type": "string" },
        "currentHostName": { "type": "string" }
      },
      "required": ["id", "name", "status" ]
    },
    "Product": {
      "title": "Product",
      "description": "Inventory item",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "stock": { "type": "number" },
        "category": { "type": "string", "enum": ["Bebidas", "Snacks", "Sexshop", "Servicios", "VIP / Promos", "Otros"] },
        "images": { "type": "array", "items": { "type": "string" } },
        "description": { "type": "string" }
      },
      "required": ["id", "name", "price", "stock", "category"]
    },
    "Promo": {
      "title": "Promo",
      "description": "Informational images and info (renamed to Info in UI)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "images"]
    },
    "Ticket": {
      "title": "Ticket",
      "description": "A completed stay receipt",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "roomId": { "type": "string" },
        "roomName": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" },
        "products": { "type": "array" },
        "services": { "type": "array" },
        "total": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "hostName": { "type": "string" }
      },
      "required": ["id", "roomId", "roomName", "startTime", "endTime", "products", "services", "total", "date", "hostName"]
    },
    "Expense": {
      "title": "Expense",
      "description": "A registered expense",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "description": { "type": "string" },
        "amount": { "type": "number" },
        "category": { "type": "string", "enum": ["Agua", "Luz", "Internet", "Aseo", "Pago Host", "Otros"] },
        "date": { "type": "string", "format": "date-time" },
        "hostName": { "type": "string" }
      },
      "required": ["id", "description", "amount", "category", "date", "hostName"]
    },
    "Reservation": {
      "title": "Reservation",
      "description": "A room reservation",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "roomId": { "type": "string" },
        "roomName": { "type": "string" },
        "date": { "type": "string", "format": "date-time", "description": "ISO string of the reservation time" },
        "clientName": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "cancelled", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "roomId", "roomName", "date", "clientName", "status", "createdAt"]
    }
  },
  "firestore": {
    "/app_users/{userId}": {
      "schema": { "$ref": "#/entities/AppUser" },
      "description": "System users with PIN authentication"
    },
    "/rooms/{roomId}": {
      "schema": { "$ref": "#/entities/Room" },
      "description": "Motel rooms"
    },
    "/products/{productId}": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Inventory products"
    },
    "/tickets/{ticketId}": {
      "schema": { "$ref": "#/entities/Ticket" },
      "description": "Completed stay tickets"
    },
    "/expenses/{expenseId}": {
      "schema": { "$ref": "#/entities/Expense" },
      "description": "Registered expenses"
    },
    "/reservations/{reservationId}": {
      "schema": { "$ref": "#/entities/Reservation" },
      "description": "Room reservations"
    },
    "/promos/{promoId}": {
      "schema": { "$ref": "#/entities/Promo" },
      "description": "Promotional images and info"
    }
  }
}
